# ============================================================
# FICHIER D'ENVIRONNEMENT — Pascal Hamm Immobilier
# ============================================================
# 1. Copiez ce fichier : cp .env.example .env
# 2. Remplissez TOUTES les valeurs
# 3. NE JAMAIS committer .env (il est dans .gitignore)
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME="Pascal Hamm Immobilier"
APP_URL=https://pascal-hamm-immobilier.fr
APP_EMAIL=contact@pascal-hamm-immobilier.fr
APP_ENV=production
# production | staging | development
APP_DEBUG=false
# true uniquement en developpement local

APP_PHONE="+33 5 XX XX XX XX"
APP_SIRET="XXX XXX XXX XXXXX"

# ── Base de donnees MySQL/MariaDB ────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=site_immo
DB_USER=site_immo_user
DB_PASS=motdepassefort
DB_CHARSET=utf8mb4
# Optionnel (hébergeurs mutualisés) :
# DB_SOCKET=/var/lib/mysql/mysql.sock
# Alias compatibles aussi acceptés :
# DB_DATABASE, DB_USERNAME, DB_PASSWORD

# ── Session PHP ───────────────────────────────────────────────
SESSION_NAME=edo_immo_sess
SESSION_LIFE=28800
# Duree en secondes : 28800 = 8 heures

# ── SMTP (envoi d emails) ─────────────────────────────────────
MAIL_FROM=contact@pascal-hamm-immobilier.fr
MAIL_FROM_NAME="Pascal Hamm Immobilier"

SMTP_HOST=mail.pascal-hamm-immobilier-aix-en-provence.fr
SMTP_PORT=465
# 465 = SSL (recommande) | 587 = TLS
SMTP_USER=contact@pascal-hamm-immobilier-aix-en-provence.fr
SMTP_PASS=motdepassesmtp
SMTP_FROM=contact@pascal-hamm-immobilier-aix-en-provence.fr
SMTP_FROM_NAME="Pascal Hamm Immobilier"
SMTP_SECURE=ssl

# ── IMAP (réception emails — Messagerie intégrée) ─────────────
# Par défaut réutilise SMTP_HOST/USER/PASS — renseignez seulement si différent
IMAP_HOST=
IMAP_PORT=993
# 993 = SSL (recommandé) | 143 = sans SSL
IMAP_USER=
IMAP_PASS=
IMAP_SECURE=ssl

# ── Notification email ────────────────────────────────────────
NOTIF_EMAIL=votre@email.fr
# Email qui recoit les demandes de contact et estimations

# ── Google My Business API ───────────────────────────────────
GMB_ACCOUNT_ID=
# Format : accounts/XXXXXXXXXX
GMB_CLIENT_ID=
GMB_CLIENT_SECRET=
GMB_REFRESH_TOKEN=

# ── Gmail API (Messagerie intégrée) ──────────────────────────
# Meme app Google Cloud que GMB — ajoutez le scope gmail.modify
# Le conseiller connecte son propre compte via OAuth2 dans l'admin
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Les tokens sont stockés automatiquement en DB après connexion

# ── Google Analytics ─────────────────────────────────────────
GA_MEASUREMENT_ID=
# Format : G-XXXXXXXXXX
SEARCH_CONSOLE_VERIFICATION=
# Code meta de verification Google Search Console

# ── IA — Anthropic / Claude (Assistant Noah) ─────────────────
ANTHROPIC_API_KEY=
# Obligatoire pour l'Assistant IA (module assistant)
# Générer sur : https://console.anthropic.com/
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Modèle par défaut — peut être surchargé sans modifier le code

# ── OpenAI (generation de contenu) ───────────────────────────
OPENAI_API_KEY=
# Optionnel — utilisé par Social, Messagerie IA

# ── Mistral AI (optionnel) ───────────────────────────────────
MISTRAL_API_KEY=
# Optionnel — fournisseur IA alternatif

# ── DataForSEO (SEO — positions & volumes) ───────────────────
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
# Compte sur https://dataforseo.com/

# ── Supabase (import biens — module Importer) ────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
# Clé anonyme Supabase — NE JAMAIS hardcoder dans le code PHP
# Obtenir une nouvelle clé : https://app.supabase.com/ → Settings → API

# ── Securite ──────────────────────────────────────────────────
APP_KEY=base64:VotreCleDeSessionUnique
APP_ENCRYPT_KEY=
# Clé de chiffrement AES-256 pour les settings sensibles (32+ bytes hex)
# Générer : php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=
# Clé de chiffrement pour le modèle ApiConfig (Cloudinary, etc.)
# Générer : php -r "echo bin2hex(random_bytes(32));"
SESSION_NAME=pascalhamm_sess

CSRF_SECRET=remplacez_par_64_caracteres_aleatoires
# Generer avec : php -r "echo bin2hex(random_bytes(32));"
