# ============================================================
# FICHIER D'ENVIRONNEMENT — Eduardo Desul Immobilier
# ============================================================
# 1. Copiez ce fichier : cp .env.example .env
# 2. Remplissez TOUTES les valeurs
# 3. NE JAMAIS committer .env (il est dans .gitignore)
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME="Eduardo Desul Immobilier"
APP_URL=https://eduardo-desul-immobilier.fr
APP_EMAIL=contact@eduardo-desul-immobilier.fr
APP_ENV=production
# production | staging | development
APP_DEBUG=false
# true uniquement en developpement local

APP_PHONE="+33 5 XX XX XX XX"
APP_SIRET="XXX XXX XXX XXXXX"

# ── Base de donnees MySQL/MariaDB ────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=site_immo
DB_USER=site_immo_user
DB_PASS=motdepassefort
DB_CHARSET=utf8mb4
# Optionnel (hébergeurs mutualisés) :
# DB_SOCKET=/var/lib/mysql/mysql.sock
# Alias compatibles aussi acceptés :
# DB_DATABASE, DB_USERNAME, DB_PASSWORD

# ── Session PHP ───────────────────────────────────────────────
SESSION_NAME=edo_immo_sess
SESSION_LIFE=28800
# Duree en secondes : 28800 = 8 heures

# ── SMTP (envoi d emails) ─────────────────────────────────────
MAIL_FROM=contact@eduardo-desul-immobilier.fr
MAIL_FROM_NAME="Eduardo Desul Immobilier"

SMTP_HOST=mail.example.com
SMTP_PORT=587
# 587 = TLS (recommande) | 465 = SSL
SMTP_USER=contact@eduardo-desul-immobilier.fr
SMTP_PASS=motdepassesmtp
SMTP_FROM=contact@eduardo-desul-immobilier.fr
SMTP_FROM_NAME="Eduardo Desul Immobilier"
SMTP_SECURE=tls

# ── Notification email ────────────────────────────────────────
NOTIF_EMAIL=votre@email.fr
# Email qui recoit les demandes de contact et estimations

# ── Google My Business API ───────────────────────────────────
GMB_ACCOUNT_ID=
# Format : accounts/XXXXXXXXXX
GMB_CLIENT_ID=
GMB_CLIENT_SECRET=
GMB_REFRESH_TOKEN=

# ── Google Analytics ─────────────────────────────────────────
GA_MEASUREMENT_ID=
# Format : G-XXXXXXXXXX
SEARCH_CONSOLE_VERIFICATION=
# Code meta de verification Google Search Console

# ── OpenAI (generation de contenu) ───────────────────────────
OPENAI_API_KEY=
# Optionnel

# ── Securite ──────────────────────────────────────────────────
CSRF_SECRET=remplacez_par_64_caracteres_aleatoires
# Generer avec : php -r "echo bin2hex(random_bytes(32));"
