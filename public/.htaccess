<IfModule mod_rewrite.c>
    RewriteEngine On

    # Ne pas réécrire les fichiers existants
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Assurez-vous que les fichiers CSS sont servis avec le bon type MIME
    RewriteCond %{REQUEST_URI} \.css$
    RewriteRule ^ - [L,T=text/css]

    # Réécrire toutes les autres requêtes vers index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Assurez-vous que les fichiers CSS sont servis avec le bon type MIME
<IfModule mod_mime.c>
    AddType text/css .css
</IfModule>

# Désactivez le parsing PHP pour les fichiers CSS
<FilesMatch "\.css$">
    SetHandler default-handler
</FilesMatch>
