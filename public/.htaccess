<IfModule mod_rewrite.c>
    Options -Indexes
    RewriteEngine On
    RewriteBase /

    # Redirection vers HTTPS + version canonique sans www
    RewriteCond %{HTTPS} !=on [OR]
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://pascalhamm.fr%{REQUEST_URI} [L,R=301]

    # 302 -> 301 pour anciennes URLs marketing
    RewriteRule ^merci-estimation/?$ /merci [L,R=301]
    RewriteRule ^merci-rdv/?$ /merci [L,R=301]

    # 410 pour pages définitivement supprimées
    RewriteRule ^old-biens/?$ - [G,L]

    # Rediriger les requêtes vers le front controller
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]

    # Gérer les erreurs
    ErrorDocument 404 /404.php
    ErrorDocument 500 /500.php
</IfModule>
